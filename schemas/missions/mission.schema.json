{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JeanBot Mission",
  "type": "object",
  "required": ["workspaceId", "userId", "title", "objective", "requiredCapabilities"],
  "properties": {
    "workspaceId": { "type": "string" },
    "userId": { "type": "string" },
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "context": { "type": "string" },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
