# JeanBot environment example
# Format:
# VARIABLE=value
# Comment lines explain where to get the value, an example shape, and whether it is required.

# Required. Local environment name.
# Example: development
NODE_ENV=development

# Required. Public HTTP port for the process you are starting.
# Example: 8080
PORT=8080

# Required. Default local user workspace path.
# Example: ./workspace/users/{userId}
JEANBOT_DEFAULT_WORKSPACE=./workspace/users/{userId}

# Required. Default local tenant workspace path.
# Example: ./workspace/tenants/{workspaceId}
JEANBOT_DEFAULT_TENANT=./workspace/tenants/{workspaceId}

# Required for legacy local access. Example shape: jean_xxxxxxxxxxxxxxxxxxxxxxxx
# In production, prefer the bootstrap flow that creates scoped API keys automatically.
JEANBOT_API_KEY=change-me

# Required if you want the gateway to reject unauthenticated requests.
# Example: true or false
JEANBOT_AUTH_REQUIRED=false

# Required. Chooses local in-process services or signed HTTP internal services.
# Example: local or http
JEANBOT_SERVICE_MODE=local

# Required. Chooses JSON fallback or Postgres-backed persistence.
# Example: local or postgres
JEANBOT_PERSISTENCE_MODE=local

# Required. Chooses local queue handling or Redis/BullMQ workers.
# Example: local or redis
JEANBOT_QUEUE_MODE=local

# Required for HTTP service mode. Shared secret used on internal service requests.
# Generate one with a password manager. Example shape: jeanbot-internal-dev-token
INTERNAL_SERVICE_TOKEN=jeanbot-internal-dev-token

# Optional. GitHub personal access token from GitHub -> Settings -> Developer settings -> Personal access tokens.
# Example shape: github_pat_11ABCDEFxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# Optional. Enables Playwright live mode instead of synthetic fallback.
# Example: true or false
PLAYWRIGHT_LIVE=false

# Required. Controls structured log verbosity.
# Example: info
LOG_LEVEL=info

# Optional. Sentry DSN from Sentry Project Settings -> Client Keys (DSN).
# Example shape: https://abc123@example.ingest.sentry.io/123456
SENTRY_DSN=

# Optional. OpenAI API key from platform.openai.com -> API keys.
# Used for live OpenAI provider calls and future embeddings.
# Example shape: sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# Optional. Anthropic API key from console.anthropic.com -> API Keys.
# Used for live Claude runtime execution.
# Example shape: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# Optional. Preferred model provider across runtime routing and sub-agent templates.
# Set to ollama if you want JeanBot missions to use Ollama by default.
# Example: ollama
JEANBOT_MODEL_PROVIDER=

# Optional. Ollama API key from ollama.com -> API Keys.
# Required for direct ollama.com API access. Not required for plain local localhost usage.
# Example shape: c56382373bea4310b1da09a82216c880.kti-xxxxxxxxxxxx
OLLAMA_API_KEY=

# Optional. Ollama API base URL.
# Local daemon example: http://localhost:11434
# Direct cloud example: https://ollama.com/api
OLLAMA_BASE_URL=http://localhost:11434

# Optional. Default Ollama model for runtime execution and provider preference routing.
# Example: glm-5:cloud
OLLAMA_MODEL=glm-5:cloud

# Optional. Resend API key from resend.com -> API Keys.
# Used for live email delivery in communication-service.
# Example shape: re_xxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=

# Optional. Default from-email used by communication-service when live email delivery is enabled.
# Configure this in your mail provider dashboard/domain settings.
# Example: jeanbot@example.com
COMMUNICATION_FROM_EMAIL=

# Optional. Slack Incoming Webhook URL from api.slack.com -> Incoming Webhooks.
# Used for live Slack delivery in communication-service.
# Example shape: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=

# Optional. Push delivery gateway endpoint for live push notifications.
# Example: https://push.example.com/send
PUSH_GATEWAY_URL=

# Optional. Stripe secret key from dashboard.stripe.com -> Developers -> API keys.
# Used by billing-service when live customer/portal context exists.
# Example shape: sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_SECRET_KEY=

# Optional. Stripe webhook signing secret from dashboard.stripe.com -> Developers -> Webhooks.
# Used to verify inbound Stripe events in live billing mode.
# Example shape: whsec_YOUR_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=

# Optional. Stripe dashboard or portal base URL override.
# Example: https://dashboard.stripe.com
STRIPE_PORTAL_BASE_URL=

# Optional for local JSON mode. Required for Postgres/Prisma mode.
# Local Docker example: postgres://postgres:postgres@localhost:5432/jeanbot
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/jeanbot

# Optional for local queue mode. Required for Redis/BullMQ queue mode.
# Local Docker example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Optional. Public browser-service base URL used to construct browser stream WebSocket URLs.
# Example: http://127.0.0.1:8090
BROWSER_PUBLIC_BASE_URL=http://127.0.0.1:8090

# Optional. OpenTelemetry OTLP endpoint for traces/metrics export.
# Example: http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional. Google OAuth client ID from Google Cloud Console -> APIs & Services -> Credentials.
# Used for Gmail workspace integrations.
# Example shape: 1234567890-abcdefg.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Optional. Google OAuth client secret from Google Cloud Console -> APIs & Services -> Credentials.
# Used for Gmail workspace integrations.
# Example shape: GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=

# Optional. GitHub OAuth App client ID from GitHub -> Settings -> Developer settings -> OAuth Apps.
# Used for GitHub workspace integrations.
# Example shape: Iv1.1234567890abcdef
GITHUB_CLIENT_ID=

# Optional. GitHub OAuth App client secret from GitHub -> Settings -> Developer settings -> OAuth Apps.
# Used for GitHub workspace integrations.
# Example shape: 1234567890abcdef1234567890abcdef12345678
GITHUB_CLIENT_SECRET=

# Required for encrypted workspace OAuth token storage.
# Generate a long random secret in a password manager. Example: jeanbot-prod-encryption-secret
JEANBOT_INTEGRATION_ENCRYPTION_KEY=change-me

# Optional in local mode. Required if JEANBOT_SERVICE_MODE=http and you want explicit service discovery.
# Examples: http://127.0.0.1:8081, http://127.0.0.1:8093
AUTH_SERVICE_URL=http://127.0.0.1:8081
USER_SERVICE_URL=http://127.0.0.1:8082
AGENT_ORCHESTRATOR_URL=http://127.0.0.1:8083
AGENT_RUNTIME_URL=http://127.0.0.1:8084
TOOL_SERVICE_URL=http://127.0.0.1:8085
MEMORY_SERVICE_URL=http://127.0.0.1:8086
POLICY_SERVICE_URL=http://127.0.0.1:8087
AUDIT_SERVICE_URL=http://127.0.0.1:8088
AUTOMATION_SERVICE_URL=http://127.0.0.1:8089
TERMINAL_SERVICE_URL=http://127.0.0.1:8091
COMMUNICATION_SERVICE_URL=http://127.0.0.1:8092
KNOWLEDGE_SERVICE_URL=http://127.0.0.1:8093
BILLING_SERVICE_URL=http://127.0.0.1:8094
BROWSER_SERVICE_URL=http://127.0.0.1:8090
